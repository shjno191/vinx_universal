{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vinx_universal",
  "version": "0.1.6",
  "identifier": "com.shjno191.vinx-universal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vinx_universal",
        "width": 800,
        "height": 600,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/shjno191/vinx_universal/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "RWTejE+6hk85PNdExyXgZETubI/QVwBQycWg47DwhMYpqQrwEAncS+vGC"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}